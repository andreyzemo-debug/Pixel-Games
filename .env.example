# Pixel&Games — environment variables for the /api serverless functions
# (Vercel). Copy this file to ".env" for local development with
# `vercel dev`, or add these under your Vercel Project → Settings →
# Environment Variables for production. Never commit the real ".env".
#
# (This is separate from /server/.env, which only configures the small
# standalone notification server in /server.)

# ------------------------------------------------------------
# Pixel AI (api/ai.js) — NEW
# ------------------------------------------------------------
# Secret key for the AI provider. Read only on the server
# (api/_lib/aiProvider.js) — never sent to the browser.
AI_API_KEY=

# Optional — which provider to use: "anthropic" (default) or "openai".
AI_PROVIDER=anthropic

# Optional — overrides the default model for the selected provider.
AI_MODEL=

# ------------------------------------------------------------
# Existing — Google Sheets (Apps Script) backend
# ------------------------------------------------------------
GOOGLE_SHEETS_WEBAPP_URL=

# ------------------------------------------------------------
# Existing — Telegram bot / notifications / admin panel
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_SESSION_SECRET=
SETUP_SECRET=
SITE_URL=
SITE_PUBLIC_URL=
SUPPORT_TELEGRAM_USERNAME=
